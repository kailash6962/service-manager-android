<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_container_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_header"
            style="@style/WidgetHeaderTitleText"
            android:text="@string/widget_header_title" />

        <TextView
            android:id="@+id/widget_add"
            style="@style/WidgetHeaderPlusText"
            android:text="@string/widget_header_add" />
    </LinearLayout>

    <TextView
        android:id="@+id/empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:singleLine="true"
        android:text="@string/widget_no_pending_services"
        android:textColor="@color/widget_text"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/service_heading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/widget_heading_service"
        android:textAllCaps="true"
        android:textColor="@color/widget_header"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium" />

    <LinearLayout
        android:id="@+id/service_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/service_row_check_1"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_checkbox_empty" />

        <TextView
            android:id="@+id/service_row_title_1"
            style="@style/WidgetRowTitleText"
            android:text="@string/widget_placeholder_row" />

        <TextView
            android:id="@+id/service_row_status_1"
            style="@style/WidgetRowStatusText"
            android:text="@string/widget_placeholder_status" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/service_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/service_row_check_2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_checkbox_empty" />

        <TextView
            android:id="@+id/service_row_title_2"
            style="@style/WidgetRowTitleText"
            android:text="@string/widget_placeholder_row" />

        <TextView
            android:id="@+id/service_row_status_2"
            style="@style/WidgetRowStatusText"
            android:text="@string/widget_placeholder_status" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/service_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/service_row_check_3"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_checkbox_empty" />

        <TextView
            android:id="@+id/service_row_title_3"
            style="@style/WidgetRowTitleText"
            android:text="@string/widget_placeholder_row" />

        <TextView
            android:id="@+id/service_row_status_3"
            style="@style/WidgetRowStatusText"
            android:text="@string/widget_placeholder_status" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/service_row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/service_row_check_4"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_checkbox_empty" />

        <TextView
            android:id="@+id/service_row_title_4"
            style="@style/WidgetRowTitleText"
            android:text="@string/widget_placeholder_row" />

        <TextView
            android:id="@+id/service_row_status_4"
            style="@style/WidgetRowStatusText"
            android:text="@string/widget_placeholder_status" />
    </LinearLayout>

    <TextView
        android:id="@+id/spare_purchase_heading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/widget_heading_spare_purchase"
        android:textAllCaps="true"
        android:textColor="@color/widget_header"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium" />

    <LinearLayout
        android:id="@+id/spare_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/spare_row_check_1"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_checkbox_empty" />

        <TextView
            android:id="@+id/spare_row_title_1"
            style="@style/WidgetRowTitleText"
            android:text="@string/widget_placeholder_row" />

        <TextView
            android:id="@+id/spare_row_status_1"
            style="@style/WidgetRowStatusText"
            android:text="@string/widget_placeholder_status" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/spare_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/spare_row_check_2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_checkbox_empty" />

        <TextView
            android:id="@+id/spare_row_title_2"
            style="@style/WidgetRowTitleText"
            android:text="@string/widget_placeholder_row" />

        <TextView
            android:id="@+id/spare_row_status_2"
            style="@style/WidgetRowStatusText"
            android:text="@string/widget_placeholder_status" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/spare_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/spare_row_check_3"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_checkbox_empty" />

        <TextView
            android:id="@+id/spare_row_title_3"
            style="@style/WidgetRowTitleText"
            android:text="@string/widget_placeholder_row" />

        <TextView
            android:id="@+id/spare_row_status_3"
            style="@style/WidgetRowStatusText"
            android:text="@string/widget_placeholder_status" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/spare_row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/spare_row_check_4"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_checkbox_empty" />

        <TextView
            android:id="@+id/spare_row_title_4"
            style="@style/WidgetRowTitleText"
            android:text="@string/widget_placeholder_row" />

        <TextView
            android:id="@+id/spare_row_status_4"
            style="@style/WidgetRowStatusText"
            android:text="@string/widget_placeholder_status" />
    </LinearLayout>

</LinearLayout>
