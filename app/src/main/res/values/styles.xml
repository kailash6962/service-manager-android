<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="WidgetHeaderTitleText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">@color/widget_header</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="WidgetHeaderPlusText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/widget_plus</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="WidgetRowTitleText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/widget_text</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="WidgetRowStatusText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/widget_status_muted_text</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/widget_status_muted_bg</item>
    </style>
</resources>
